# orq
ORQ_API_KEY=
ORQ_AGENT_KEY=bmo_demo
ORQ_MODEL=openai/gpt-4o
ORQ_VISION_MODEL=openai/gpt-4o
ORQ_STT_MODEL=openai/whisper-1
ORQ_TTS_MODEL=openai/tts-1
ORQ_TTS_VOICE=alloy
ORQ_WORKSPACE_URL=https://my.orq.ai

# Mode: "orq" (default — STT→agent→TTS via orq.ai) or "realtime" (OpenAI
# Realtime speech-to-speech, sub-second latency, barge-in). Realtime mode
# bypasses orq for inference but still pulls system prompt from orq/agent.json.
BMO_MODE=orq
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy

# pi audio
MIC_DEVICE_INDEX=
SAMPLE_RATE=16000

# wakeword
WAKEWORD_PATH=wakeword.onnx
WAKEWORD_THRESHOLD=0.5

# behavior
SESSION_TIMEOUT_SEC=30
VISION_CAPTURE_TRIGGER=see|look|what.*you.*see
CAMERA_ROTATION=0

# logging
LOG_LEVEL=INFO
